rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: owner can write, anyone authenticated can read (for leaderboards/friends)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Puzzle results subcollection (used by Cloud Functions for club goals)
      match /puzzleResults/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Push token subcollection
      match /pushToken/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Daily scores: owner can write own entry, anyone can read
    // Score bounds: 0..1_000_000 (sanity ceiling to prevent trivial leaderboard cheats)
    match /dailyScores/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000;
    }

    // Weekly scores: same pattern
    match /weeklyScores/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000;
    }

    // Friendships: participants can read/write
    match /friendships/{friendshipId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.users;
      allow update: if request.auth != null && request.auth.uid in resource.data.users;
      allow delete: if request.auth != null && request.auth.uid in resource.data.users;
    }

    // Gifts: sender can create, recipient can read/update (claim)
    match /gifts/{giftId} {
      allow create: if request.auth != null && request.resource.data.fromUserId == request.auth.uid;
      allow read: if request.auth != null &&
        (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid);
      allow update: if request.auth != null && resource.data.toUserId == request.auth.uid;
    }

    // Clubs: members can read/write, anyone can create
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.memberIds;

      // Club messages
      // Must be a club member. Message size is capped server-side to prevent
      // oversize payloads. Delete is allowed by the author (for self-moderation)
      // or by the server (via Cloud Functions) for report-driven removal.
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 200;
        allow delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }

      // Club goals (managed by Cloud Functions)
      match /goals/{goalId} {
        allow read: if request.auth != null;
      }
    }

    // Reports (user-generated reports of other users or messages)
    // Reporters can create; only server (admin) can read. Keeps reports private.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in ['message', 'user']
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500;
      // Admin-only read/write — reads return nothing to clients
      allow read, update, delete: if false;
    }

    // Block list: each user owns their own block entries
    match /users/{userId}/blockedUsers/{blockedUserId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ToS acceptance ledger: each user writes their own acceptance record
    match /users/{userId}/consent/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard snapshots (written by Cloud Functions, read by anyone)
    match /leaderboards/{leaderboardId} {
      allow read: if request.auth != null;
    }

    // Rate-limit counters (server-side only — clients must never read/write).
    // Cloud Functions bump these atomically under checkFirestoreRateLimit;
    // exposing them to clients would let attackers clear their own bucket.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }
  }
}
