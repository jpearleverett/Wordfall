{
  "expo": {
    "name": "Wordfall",
    "slug": "wordfall",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#060918"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wordfall.app",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wordfall.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#060918"
      },
      "permissions": []
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00d4ff",
          "sounds": []
        }
      ],
      "expo-video",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "wordfall-production"
      }
    },
    "owner": "wordfall"
  }
}
