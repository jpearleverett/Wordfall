{
  "expo": {
    "name": "Wordfall",
    "slug": "wordfall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#060918"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wordfall.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wordfall.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon2.png",
        "backgroundColor": "#060918"
      },
      "permissions": []
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "owner": "wordfall"
  }
}
