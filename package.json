  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.3.0",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.42.0",
