{
  "name": "wordfall",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "maestro test .maestro/",
    "optimize-assets": "bash scripts/optimize-assets.sh",
    "harness:build": "node web-harness/esbuild.config.mjs",
    "harness:watch": "node web-harness/esbuild.config.mjs --watch",
    "screenshots": "node scripts/take-screenshots.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
