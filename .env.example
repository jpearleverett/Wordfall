# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials.
# These are required for authentication and cloud features to work.
# Get these values from: Firebase Console > Project Settings > General > Your apps

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Services
EXPO_PUBLIC_FIREBASE_FUNCTIONS_URL=
EXPO_PUBLIC_SENTRY_DSN=
# AdMob ad unit IDs — defaults are Google's public test units (safe for dev).
# Replace with real units from AdMob Console before production release.
EXPO_PUBLIC_ADMOB_REWARDED_ID=ca-app-pub-3940256099942544/5224354917
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712
