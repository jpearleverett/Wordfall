# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials.
# These are required for authentication and cloud features to work.
# Get these values from: Firebase Console > Project Settings > General > Your apps

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Services
EXPO_PUBLIC_FIREBASE_FUNCTIONS_URL=
EXPO_PUBLIC_SENTRY_DSN=
# AdMob ad unit IDs — platform-specific. Ad units created in AdMob Console
# are scoped to one platform's app ID; the same string will not serve on
# the other platform.
#
# Resolution order (in src/constants.ts):
#   1. EXPO_PUBLIC_ADMOB_*_ID_ANDROID  (Android only)
#   1. EXPO_PUBLIC_ADMOB_*_ID_IOS      (iOS only)
#   2. EXPO_PUBLIC_ADMOB_*_ID          (legacy shared fallback)
#   3. Google's public test ad unit IDs (always safe for dev)
#
# Leave any of these blank to fall through to test IDs.
EXPO_PUBLIC_ADMOB_REWARDED_ID_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_ID_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_IOS=
